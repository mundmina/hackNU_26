JWT_SECRET=change-me-in-production
ACCESS_TOKEN_MINUTES=720
STALE_AFTER_SECONDS=10
MAX_STREAM_QUEUE=128
TELEMETRY_BUFFER_SIZE=2048
APP_USERS_JSON={"operator":{"password":"demo123","role":"operator"},"admin":{"password":"admin123","role":"admin"}}

# Redis pub/sub event bus (plan §5.3 — highload x10 spike buffer).
# When running with docker-compose the hostname is "redis" (default).
# For local dev without Docker: redis://localhost:6379/0
# Leave unset to use the in-memory fallback automatically.
REDIS_URL=redis://redis:6379/0
